# Create .gitignore file
@"
# Dependencies
node_modules/
.pnp
.pnp.js
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
__pycache__/
*.pyc
*.pyo
*.pyd

# Build outputs
build/
dist/
*.exe
*.dll

# Backend temp files
backend/temp/
backend/*.log
backend/pretrained_models/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Python
*.egg-info/
*.egg
.venv/
venv/
env/
"@ | Out-File -FilePath .gitignore -Encoding UTF8