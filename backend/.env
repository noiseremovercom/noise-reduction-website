# Server Configuration
PORT=5000
NODE_ENV=development

# File Limits
MAX_FILE_SIZE=10485760

# Allowed Origins
ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Whether to use SpeechBrain after DeepFilterNet
USE_SPEECHBRAIN = True

# Which model to use: 'metricgan+' or 'mimic'
SPEECHBRAIN_MODEL = 'metricgan+'

# Device to run on: 'cpu' or 'cuda'
SPEECHBRAIN_DEVICE = 'cpu'

# SpeechBrain Configuration
USE_SPEECHBRAIN=True
SPEECHBRAIN_MODEL=metricgan+
SPEECHBRAIN_DEVICE=cpu