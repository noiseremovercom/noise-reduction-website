# Server Configuration
PORT=5000
NODE_ENV=development

# File Limits
MAX_FILE_SIZE=52428800

# Allowed Origins (add your Render frontend URL when deployed)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.onrender.com

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ========== ADD THESE NEW API KEY VARIABLES ==========
# API Keys for mobile apps (comma-separated for multiple keys)
# Generate using: node -e "console.log('app_' + require('crypto').randomBytes(24).toString('hex'))"
VALID_API_KEYS=app_your_first_generated_key_here,app_your_second_generated_key_here

# Master API Key for admin/development (optional)
MASTER_API_KEY=master_your_master_key_here

# Rate limiting per API key (requests per hour)
API_RATE_LIMIT_PER_HOUR=100